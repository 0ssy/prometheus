{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Prometheus main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-internal-toggle-devtools",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "prometheus", "args": ["--server"] }]
    }
  ]
}
