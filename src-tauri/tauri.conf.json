{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prometheus",
  "version": "0.6.0",
  "identifier": "os.prometheus.engineering",
  "build": {
    "beforeDevCommand": "python prometheus.py --server",
    "devUrl": "http://localhost:8000/dashboard",
    "beforeBuildCommand": "cd /d C:\\Users\\josep\\Downloads\\prometheus && npm --prefix web run build && venv\\Scripts\\python.exe scripts\\build_app_exe.py",
    "frontendDist": "http://127.0.0.1:8000/dashboard"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Prometheus",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/prometheus"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "perMachine"
      }
    }
  }
}
